# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRODUCT_ID=prod_...   # optional: filter by product

# LDAP bind passwords
LDAP_BIND_PASSWORD=changeme-live-password
LDAP_DEMO_PASSWORD=changeme-demo-password

# TLS (PEM strings — use deno task gen-certs for dev)
TLS_CERT_PEM="-----BEGIN CERTIFICATE-----
...
-----END CERTIFICATE-----"
TLS_KEY_PEM="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"

# Optional overrides
CACHE_TTL_MS=300000
LDAP_PORT=636
HTTP_PORT=8080
