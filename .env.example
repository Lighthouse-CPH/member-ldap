# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRODUCT_ID=prod_...   # optional: filter by product

# LDAP bind passwords
LDAP_BIND_PASSWORD=changeme-live-password
LDAP_DEMO_PASSWORD=changeme-demo-password

UID_HASH_SEED=changeme-random-secret   # secret used to HMAC-SHA256 Stripe customer IDs into LDAP UIDs

# Optional overrides
CACHE_TTL_MS=300000
LDAP_PORT=636
HTTP_PORT=8080
