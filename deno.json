{
  "imports": {
    "ldapjs": "npm:ldapjs@^3.0.0",
    "@types/ldapjs": "npm:@types/ldapjs@^3.0.6",
    "stripe": "npm:stripe@^17.0.0",
    "ldapts": "npm:ldapts@^7.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --env-file --watch src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read --env-file src/main.ts",
    "test": "deno test --allow-net --allow-env --allow-read --allow-write tests/ --ignore=tests/e2e",
    "test:e2e": "deno test --allow-net --allow-env --allow-read --allow-write --allow-run tests/e2e/",
    "test:all": "deno test --allow-net --allow-env --allow-read --allow-write --allow-run tests/",
    "test:update": "deno test --allow-net --allow-env --allow-read --allow-write -- --update tests/ --ignore=tests/e2e",
    "check": "deno check src/main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt"
  }
}
